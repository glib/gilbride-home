---
import "@fontsource-variable/montserrat";
import "@fontsource-variable/mulish";
import "../styles/global.css";
const { pageTitle } = Astro.props;
import Footer from "../components/Footer.astro";
---

<html>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="widget=device-width" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <!-- <div class="px-30 text-gray-800"><slot /></div> -->
    <div class="flex">
      <!-- Sidebar (20%) -->
      <aside class="w-1/5 p-4">
        <nav class="space-y-4">
          <a href="#" class="block text-gray-600 hover:underline">Home</a>
          <a href="#" class="block text-gray-600 hover:underline">About</a>
          <a href="#" class="block text-gray-600 hover:underline">Services</a>
          <a href="#" class="block text-gray-600 hover:underline">Contact</a>
        </nav>
      </aside>

      <!-- Main content (80%) -->
      <main class="w-4/5 p-6">
        <h1 class="text-3xl font-bold mb-4">Welcome</h1>
        <p class="text-gray-700"><slot /></p>
      </main>
    </div>
    <Footer />
  </body>
</html>
